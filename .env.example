# Starkzap — get from https://dashboard.starkzap.io
NEXT_PUBLIC_STARKZAP_APP_ID=your-app-id-here

# Reclaim Protocol — get from https://dev.reclaimprotocol.org/
NEXT_PUBLIC_RECLAIM_APP_ID=your-reclaim-app-id
RECLAIM_APP_SECRET=your-reclaim-app-secret

# Deployed contract address (after deploying ZKLend.cairo)
NEXT_PUBLIC_LENDING_CONTRACT=0x...your-contract-address

# Starknet network (mainnet or sepolia)
NEXT_PUBLIC_STARKNET_NETWORK=sepolia
